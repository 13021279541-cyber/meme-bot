# 热梗自动化 API 服务器环境变量
# 复制此文件为 .env 并填入真实值
# ⚠️ .env 不进 Git（.gitignore 已配置）

# MySQL 数据库（必填）
DB_HOST=9.134.177.112
DB_PORT=3306
DB_USER=root
DB_PASS=你的数据库密码
DB_NAME=meme_bot

# 企微智能机器人
# 企微智能机器人（多群模式，JSON 数组）
# 每个机器人：bot_id、secret、chat_id（可空，首次收到消息自动获取）、name（标识名）
BOTS=[{"bot_id":"aibXXX","secret":"xxx","chat_id":"wrkXXX","name":"主群"},{"bot_id":"aibYYY","secret":"yyy","chat_id":"","name":"体验群"}]
CHAT_TYPE=2
CHAT_TYPE=2

# 服务端口
PORT=3000
AIBOT_HTTP_PORT=4001

# 服务器地址（用于生成公开 URL，截图推送等）
SERVER_HOST=http://你的服务器IP:3000
